# ────────────────────────────────────────────────────────────────────────────
# Tempo — Enterprise Deployment Platform: example environment
#
# Local dev: copy to `.env.local` and fill in the values.
# Vercel:    `vercel env pull .env.development.local` pulls Vercel-managed env
#            vars into a local file. Do NOT commit `.env*.local`.
# ────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon Postgres) ──────────────────────────────────────────────
# Pooled connection URL (PgBouncer-compatible) used by the Prisma client at runtime.
POSTGRES_PRISMA_URL="postgres://user:pass@ep-host-pooler.eu-central-1.aws.neon.tech/tempo?sslmode=require&pgbouncer=true&connect_timeout=15"
# Direct connection URL used ONLY by `prisma migrate` (PgBouncer can't run DDL).
POSTGRES_URL_NON_POOLING="postgres://user:pass@ep-host.eu-central-1.aws.neon.tech/tempo?sslmode=require"
# Legacy alias some tools still read; keep in sync with POSTGRES_PRISMA_URL.
DATABASE_URL="${POSTGRES_PRISMA_URL}"

# ─── JWT secrets (generate with: openssl rand -base64 48) ──────────────────
# Rotating JWT_ACCESS_SECRET also invalidates the playlist-wizard HMAC cookie.
# See DEPLOYMENT-INSIGHTS.md → Secrets rotation for the two-phase procedure.
JWT_ACCESS_SECRET="replace-with-random-48-byte-base64-secret-access"
JWT_REFRESH_SECRET="replace-with-random-48-byte-base64-secret-refresh"

# ─── Webhook HMAC (Stripe-style billing signature verification) ────────────
WEBHOOK_SECRET="replace-with-random-webhook-secret"

# ─── Cookies ───────────────────────────────────────────────────────────────
# Leave blank for single-host deploys. Set to ".tempo.example.dev" for
# cross-subdomain cookie sharing (e.g. api.tempo.example.dev ↔ tempo.example.dev).
COOKIE_DOMAIN=""

# ─── Vercel Blob (playlist cover uploads) ──────────────────────────────────
# Auto-injected in Vercel envs when the Blob store is connected.
BLOB_READ_WRITE_TOKEN=""

# ─── Upstash Redis (distributed rate limiter) ──────────────────────────────
# Required in production. Falls back to in-memory token bucket when both are unset.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Sentry (error tracking + performance) ─────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Required ONLY in CI (source-map upload). Keep blank locally.
SENTRY_AUTH_TOKEN=""

# ─── Deploy-time config ────────────────────────────────────────────────────
# Base URL of the deployed site, used for absolute links and Lighthouse targets.
NEXT_PUBLIC_SITE_URL="https://tempo.example.dev"
# Must be `true` to allow `npm run db:seed` in anything other than NODE_ENV=development.
ALLOW_SEED=""
# Standard Node flag; Vercel sets this automatically.
NODE_ENV="development"
